# deploy/.env.example — copy to deploy/.env and fill in.
# Real .env is gitignored; do NOT commit secrets.

# --- Shared ---
DAES_SEED=0xDEADBEEF               # 32-byte hex; dev-only swarm seed fallback
GRAFANA_ADMIN_PASSWORD=change-me   # Grafana admin pw (dev only)

# --- Swarm seed source (prod: Chainlink VRF on-chain, dev: leave blank) ---
# When both are set, the swarm runtime reads SwarmSeedVRF.latestSeed() via
# eth_call. Deploy the contract with contracts/scripts/ first, then set:
SEED_VRF_RPC=
SEED_VRF_CONTRACT=

# --- Weaviate / MCP ---
WEAVIATE_API_KEY=dev-weaviate-key
MCP_JWT=eyJhbGciOiJIUzI1NiJ9.<signed-with-MCP_JWT_SECRET>
MCP_JWT_SECRET=replace-with-32-byte-base64-secret

# --- RPC endpoints ---
# Testnet (Tier 2 default targets)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
OP_SEPOLIA_RPC_URL=https://sepolia.optimism.io
# Mainnet (Tier 4 — deploys here are gated by DAES_ALLOW_MAINNET=1)
BASE_RPC_URL=https://mainnet.base.org
OP_RPC_URL=https://mainnet.optimism.io
# TENDERLY_URL is optional; if empty, contract_call_simulate falls back to local Anvil
TENDERLY_URL=

# --- Contract deployment roles (used by contracts/scripts/deploy.ts) ---
# DEPLOYER_PRIVATE_KEY must be a funded EOA on the target chain.
# Every DAES_* role below must be a 0x-prefixed 40-hex-char address.
# Generate distinct EOAs per role and store private keys in a secrets
# manager — the contracts only ever hold the addresses.
DEPLOYER_PRIVATE_KEY=
DAES_SIGNER_1=
DAES_SIGNER_2=
DAES_SIGNER_3=
DAES_SIGNER_4=
DAES_SIGNER_5=
DAES_BRIDGE_OPERATOR=
DAES_POSTER=
DAES_HUMAN_GUARDIAN=
# Uncomment ONLY after Tier 4 is complete (audit + cross-chain replay protection).
# DAES_ALLOW_MAINNET=1

# --- Data sources (optional; pipelines silently fall back if absent) ---
AISSTREAM_API_KEY=
DHL_API_KEY=
MAERSK_API_KEY=
CUSTOMS_API_BASE=
WEB3_STORAGE_TOKEN=

# --- Tenderly simulation (optional; falls back to local Anvil eth_call) ---
# Format: https://api.tenderly.co/api/v1/account/<acct>/project/<proj>
TENDERLY_URL=
TENDERLY_ACCESS_KEY=

# --- Pimlico ERC-4337 bundler (optional; wallet_sign returns signed op only if absent) ---
PIMLICO_API_KEY=

# --- Agent keys (at least AGENT_KEY_DEFAULT required for wallet_sign_transaction) ---
# Format: 0x-prefixed 32-byte hex private key. Provision distinct keys per archetype
# in prod via secrets manager; never commit.
AGENT_KEY_DEFAULT=
AGENT_KEY_SPECULATOR=
AGENT_KEY_ARBITRAGEUR=
AGENT_KEY_SOVEREIGN=
AGENT_KEY_MARKETMAKER=
AGENT_KEY_BLACKSWAN=

# --- Frontend ---
NEXT_PUBLIC_GRAFANA_URL=http://localhost:3000

# --- Production TLS (only needed with deploy/docker-compose.prod.yaml) ---
# When set, the Caddy overlay terminates HTTPS with a real Let's Encrypt cert
# for these hostnames. Leave unset for local dev (the self-signed cert from
# deploy/tls/generate-cert.sh is used instead).
DAES_PUBLIC_DOMAIN=
DAES_CONSOLE_DOMAIN=
DAES_ACME_EMAIL=

# --- IPFS private swarm + public HTTP gateway (prod overlay only) ---
# The kubo daemon runs with LIBP2P_FORCE_PNET=1 and mounts
# deploy/ipfs/swarm.key (generate with deploy/ipfs/generate-swarm-key.sh).
# The HTTP gateway is fronted by Caddy with basic_auth. Generate
# DAES_IPFS_PASS_HASH with:   docker run --rm caddy:2.8.4-alpine caddy hash-password
DAES_IPFS_DOMAIN=
DAES_IPFS_USER=
DAES_IPFS_PASS_HASH=
