# deploy/.env.staging.example — copy to deploy/.env.staging and fill in.
#
# Staging is the dress rehearsal for prod: same compose overlays, same
# Caddy / IPFS / mcp-gateway wiring, distinct hostnames + secrets so a
# bad rehearsal can't bleed into production. The real file is gitignored.
#
# Workflow (see docs/runbook.md for the long-form):
#   1. cp deploy/.env.staging.example deploy/.env.staging
#   2. fill staging hostnames + staging-only secrets
#   3. bash deploy/deploy-staging.sh                    # builds HEAD, tags by sha
#   4. bash deploy/promote-to-prod.sh                   # only if staging smoke passed
#
# Every variable here matches deploy/.env.example. The diff is:
#   - DAES_*_DOMAIN point at *.staging.<your-domain> rather than prod hosts
#   - DAES_ALLOW_MAINNET stays unset (staging never touches L1 mainnet)
#   - keys, secrets, signer addresses are STAGING ones — never copy prod values

# --- Shared ---
DAES_SEED=0xCAFEBABE                  # dev-only fallback; SEED_VRF_* takes priority when set
GRAFANA_ADMIN_PASSWORD=staging-change-me

# --- Swarm seed source ---
# Staging should point at a testnet-deployed SwarmSeedVRF, not the prod one.
SEED_VRF_RPC=
SEED_VRF_CONTRACT=

# --- Weaviate / MCP ---
WEAVIATE_API_KEY=staging-weaviate-key
MCP_JWT=eyJhbGciOiJIUzI1NiJ9.<staging-jwt>
MCP_JWT_SECRET=staging-32-byte-base64-secret

# --- RPC endpoints ---
# Staging should target Sepolia, not mainnet, even if prod runs mainnet.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
OP_SEPOLIA_RPC_URL=https://sepolia.optimism.io
BASE_RPC_URL=https://sepolia.base.org
OP_RPC_URL=https://sepolia.optimism.io
TENDERLY_URL=

# --- Contract deployment roles ---
# Staging keys MUST be distinct from prod. Generate fresh EOAs.
DEPLOYER_PRIVATE_KEY=
DAES_SIGNER_1=
DAES_SIGNER_2=
DAES_SIGNER_3=
DAES_SIGNER_4=
DAES_SIGNER_5=
DAES_BRIDGE_OPERATOR=
DAES_POSTER=
DAES_HUMAN_GUARDIAN=
# DAES_ALLOW_MAINNET stays UNSET in staging. Do not uncomment.

# --- Data sources (optional) ---
AISSTREAM_API_KEY=
DHL_API_KEY=
MAERSK_API_KEY=
CUSTOMS_API_BASE=
WEB3_STORAGE_TOKEN=

# --- Tenderly simulation (optional) ---
TENDERLY_URL=
TENDERLY_ACCESS_KEY=

# --- Pimlico ERC-4337 bundler (optional) ---
PIMLICO_API_KEY=

# --- Agent keys ---
# Staging-only keys; the swarm will sign rehearsal txs with these.
AGENT_KEY_DEFAULT=
AGENT_KEY_SPECULATOR=
AGENT_KEY_ARBITRAGEUR=
AGENT_KEY_SOVEREIGN=
AGENT_KEY_MARKETMAKER=
AGENT_KEY_BLACKSWAN=

# --- Frontend ---
NEXT_PUBLIC_GRAFANA_URL=https://grafana.staging.example

# --- Production TLS (Caddy overlay terminates here too) ---
# Use a *.staging.<your-domain> namespace so prod LE certs are never
# reissued by a staging deploy run. ACME-staging email is fine here.
DAES_PUBLIC_DOMAIN=daes.staging.example
DAES_CONSOLE_DOMAIN=console.staging.example
DAES_ACME_EMAIL=ops-staging@example
DAES_IPFS_DOMAIN=ipfs.staging.example
DAES_IPFS_USER=staging-operator
DAES_IPFS_PASS_HASH=
